# Neon Postgres — get from console.neon.tech → project → connection string
DATABASE_URL=postgresql://neondb_owner:...@...neon.tech/neondb?sslmode=require

# Vercel cron auth — set this in Vercel dashboard AND here for local testing
CRON_SECRET=any_random_secret_string_you_choose

# API key for Guild agent to write metrics here (can be same as CRON_SECRET)
METRICS_API_KEY=any_random_secret_string_you_choose

# Brave Search — from search.brave.com
BRAVE_API_KEY=

# Resend — from resend.com → API Keys
RESEND_API_KEY=

# GitHub — needs repo write scope
GITHUB_TOKEN=

# Email recipients
EMAIL_TO=rod.brathwaite@gmail.com
# EMAIL_CC=casey.brathwaite@gmail.com

# Optional — enables AI synthesis in the report
# ANTHROPIC_API_KEY=

# Malloyyo base URL (informational only in Vercel version)
MALLOYYO_URL=https://malloyyo-c7i3hmkly-brathwaite.vercel.app
